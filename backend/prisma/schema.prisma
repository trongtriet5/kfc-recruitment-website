generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  fullName   String
  phone      String?
  role       String   @default("USER")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  interviews    Interview[]
  campaigns     Campaign[]
  createdProposals RecruitmentProposal[] @relation("ProposalCreator")

  @@map("users")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
  headcounts  Headcount[]
  proposals   RecruitmentProposal[]
  candidates  Candidate[]

  @@map("departments")
}

model Position {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcountPositions HeadcountPosition[]
  proposals   RecruitmentProposal[]
  requests    Request[]
  interviews  Interview[]

  @@map("positions")
}

model Store {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String
  brand       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidates  Candidate[]
  campaigns   Campaign[]
  headcounts  Headcount[]
  proposals   RecruitmentProposal[]
  requests    Request[]

  @@map("stores")
}

model RecruitmentForm {
  id          String   @id @default(cuid())
  title       String
  description String?
  brand       String
  source      String
  link        String   @unique
  formTitle   String?
  formContent String?
  bannerUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
  candidates  Candidate[]
  fields      FormField[]

  @@map("recruitment_forms")
}

model FormField {
  id          String   @id @default(cuid())
  formId      String
  name        String
  label       String
  type        String
  placeholder String?
  required    Boolean  @default(false)
  order       Int      @default(0)
  options     Json?
  width       String?
  helpText    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form        RecruitmentForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_fields")
}

model Campaign {
  id           String    @id @default(cuid())
  name         String
  description  String?
  formId       String
  link         String    @unique
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean   @default(true)
  picId        String?
  departmentId String?
  storeId      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  form         RecruitmentForm  @relation(fields: [formId], references: [id])
  pic          User?           @relation(fields: [picId], references: [id])
  department   Department?     @relation(fields: [departmentId], references: [id])
  store        Store?          @relation(fields: [storeId], references: [id])
  candidates   Candidate[]
  proposals   RecruitmentProposal[]

  @@map("campaigns")
}

model Candidate {
  id              String   @id @default(cuid())
  fullName        String
  email           String?
  phone           String
  cvUrl           String?
  formId          String?
  campaignId      String?
  brand           String?
  position        String?
  storeId         String?
  departmentId    String?
  notes           String?
  gender          String?
  dateOfBirth     DateTime?
  cccd           String?
  currentCity    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  form            RecruitmentForm?  @relation(fields: [formId], references: [id])
  campaign        Campaign?         @relation(fields: [campaignId], references: [id])
  store           Store?           @relation(fields: [storeId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  interviews      Interview[]
  proposals       RecruitmentProposal[]

  @@map("candidates")
}

model Interview {
  id           String   @id @default(cuid())
  candidateId  String
  interviewerId String
  positionId   String?
  scheduledAt  DateTime
  location    String?
  notes       String?
  result      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate    Candidate  @relation(fields: [candidateId], references: [id])
  interviewer  User       @relation(fields: [interviewerId], references: [id])
  position     Position?  @relation(fields: [positionId], references: [id])

  @@map("interviews")
}

model RecruitmentProposal {
  id           String   @id @default(cuid())
  title        String
  description  String?
  storeId      String?
  positionId   String?
  quantity     Int
  reason       String?
  status       String   @default("PENDING")
  approverId   String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  campaignId  String?
  departmentId String?
  requesterId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store        Store?          @relation(fields: [storeId], references: [id])
  position     Position?       @relation(fields: [positionId], references: [id])
  approver     User?           @relation("ProposalCreator", fields: [approverId], references: [id])
  campaign    Campaign?       @relation(fields: [campaignId], references: [id])
  department  Department?    @relation(fields: [departmentId], references: [id])
  candidates  Candidate[]

  @@map("recruitment_proposals")
}

model Request {
  id           String   @id @default(cuid())
  title        String
  description  String?
  storeId      String?
  positionId   String?
  quantity    Int?
  reason      String?
  status      String   @default("PENDING")
  requesterId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store?    @relation(fields: [storeId], references: [id])
  position    Position? @relation(fields: [positionId], references: [id])

  @@map("requests")
}

model Headcount {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  period       String
  departmentId String?
  storeId      String?
  year         Int
  month        Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id])
  store        Store?      @relation(fields: [storeId], references: [id])
  positions    HeadcountPosition[]

  @@map("headcounts")
}

model HeadcountPosition {
  id          String   @id @default(cuid())
  headcountId String
  positionId  String
  current     Int      @default(0)
  target      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcount   Headcount @relation(fields: [headcountId], references: [id], onDelete: Cascade)
  position    Position  @relation(fields: [positionId], references: [id])

  @@unique([headcountId, positionId])
  @@map("headcount_position")
}

model CandidateToRecruit {
  id           String   @id @default(cuid())
  candidateId  String
  proposalId   String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  @@map("_candidate_to_recruit")
}