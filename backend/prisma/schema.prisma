// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH & USER ============
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  fullName      String
  phone         String?
  role          UserRole @default(USER)
  departmentId  String?
  positionId    String?
  employeeId    String?  @unique
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department    Department? @relation(fields: [departmentId], references: [id])
  position      Position?    @relation(fields: [positionId], references: [id])
  employee      Employee?    @relation("EmployeeUser", fields: [employeeId], references: [id])

  timekeeping   Timekeeping[]
  interviews    Interview[]
  payrolls      Payroll[]
  
  // Relations with named relations
  approvedRequests Request[] @relation("RequestApprover")
  createdContracts Contract[] @relation("ContractCreator")
  createdDecisions Decision[] @relation("DecisionCreator")
  approvedProposals RecruitmentProposal[] @relation("ProposalApprover")

  @@map("users")
}

enum UserRole {
  ADMIN
  HEAD_OF_DEPARTMENT
  MANAGER
  SUPERVISOR
  USER
}

// ============ ORGANIZATION ============
model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  employees   Employee[]
  requests    Request[]
  headcounts  Headcount[]
  payrolls    Payroll[]

  @@map("departments")
}

model Position {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  employees   Employee[]
  headcountPositions HeadcountPosition[]
  proposals   RecruitmentProposal[]

  @@map("positions")
}

model Store {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String
  brand       Brand
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees   Employee[]
  proposals   RecruitmentProposal[]
  headcounts  Headcount[]
  candidates  Candidate[]

  @@map("stores")
}

enum Brand {
  TAM_HAO
  MAYCHA
  BOTH
}

// ============ DYNAMIC TYPES SYSTEM ============
// Hệ thống quản lý động các loại và trạng thái
model TypeCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  module      String   // Module sử dụng: EMPLOYEE, REQUEST, CONTRACT, DECISION, CANDIDATE, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  types       Type[]

  @@map("type_categories")
}

model Type {
  id          String   @id @default(cuid())
  categoryId  String
  code        String
  name        String
  description String?
  color       String?  // Màu sắc cho UI (hex code)
  icon        String?  // Icon cho UI
  order       Int      @default(0) // Thứ tự hiển thị
  isDefault   Boolean  @default(false) // Trạng thái mặc định
  isActive    Boolean  @default(true)
  metadata    Json?    // Dữ liệu bổ sung (JSON)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    TypeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Relations to other models
  employeesAsStatus       Employee[]           @relation("EmployeeStatus")
  employeesAsContractType Employee[]           @relation("EmployeeContractType")
  requestsAsType         Request[]            @relation("RequestType")
  requestsAsStatus        Request[]            @relation("RequestStatus")
  requestsAsLeaveType     Request[]            @relation("LeaveType")
  contractsAsType         Contract[]           @relation("ContractType")
  contractsAsStatus       Contract[]           @relation("ContractStatus")
  decisionsAsType         Decision[]           @relation("DecisionType")
  decisionsAsStatus       Decision[]            @relation("DecisionStatus")
  candidatesAsStatus      Candidate[]          @relation("CandidateStatus")
  interviewsAsType       Interview[]          @relation("InterviewType")
  interviewsAsResult      Interview[]          @relation("InterviewResult")
  proposalsAsStatus       RecruitmentProposal[] @relation("ProposalStatus")
  timekeepingAsStatus     Timekeeping[]        @relation("TimekeepingStatus")
  payrollsAsStatus        Payroll[]            @relation("PayrollStatus")

  @@unique([categoryId, code])
  @@map("types")
}

// ============ EMPLOYEE ============
model Employee {
  id              String          @id @default(cuid())
  employeeCode    String          @unique
  fullName        String
  email           String?         @unique
  phone           String
  gender          Gender
  dateOfBirth     DateTime?
  address         String?
  idCard          String?         @unique
  education       Education
  statusId        String?         // Thay thế EmployeeStatus enum
  departmentId    String?
  positionId      String?
  storeId         String?
  brand           Brand?
  contractTypeId  String?         // Thay thế ContractType enum
  startDate       DateTime?
  endDate         DateTime?
  salary          Decimal?        @db.Decimal(12, 2)
  insuranceNumber String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  status          Type?           @relation("EmployeeStatus", fields: [statusId], references: [id])
  contractType    Type?           @relation("EmployeeContractType", fields: [contractTypeId], references: [id])
  department      Department?     @relation(fields: [departmentId], references: [id])
  position        Position?       @relation(fields: [positionId], references: [id])
  store           Store?          @relation(fields: [storeId], references: [id])
  user            User?            @relation("EmployeeUser")
  contracts       Contract[]
  requests        Request[]
  timekeeping     Timekeeping[]
  payrolls        Payroll[]
  decisions       Decision[]

  @@map("employees")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Education {
  HIGH_SCHOOL
  VOCATIONAL
  COLLEGE
  UNIVERSITY
  POSTGRADUATE
}

// ============ REQUESTS (Đơn từ) ============
model Request {
  id            String        @id @default(cuid())
  typeId        String        // Thay thế RequestType enum
  statusId      String?       // Thay thế RequestStatus enum
  employeeId    String
  departmentId  String?
  startDate     DateTime?
  endDate       DateTime?
  reason        String?
  description   String?
  attachments   String[]      @default([])
  approverId    String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  rejectionReason String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  type          Type          @relation("RequestType", fields: [typeId], references: [id])
  status        Type?         @relation("RequestStatus", fields: [statusId], references: [id])
  leaveTypeId   String?       // Thay thế LeaveType enum
  employee      Employee      @relation(fields: [employeeId], references: [id])
  department    Department?   @relation(fields: [departmentId], references: [id])
  approver      User?         @relation("RequestApprover", fields: [approverId], references: [id])
  leaveType     Type?         @relation("LeaveType", fields: [leaveTypeId], references: [id])

  // Overtime specific
  overtimeHours Float?
  overtimeDate  DateTime?

  // Check-in/out confirmation
  checkInTime   DateTime?
  checkOutTime  DateTime?
  actualCheckIn DateTime?
  actualCheckOut DateTime?

  // Shift change
  fromShift     String?
  toShift       String?
  shiftDate     DateTime?

  // Business trip
  tripLocation  String?
  tripPurpose  String?

  @@map("requests")
}

// ============ CONTRACTS ============
model Contract {
  id          String        @id @default(cuid())
  employeeId  String
  typeId      String        // Thay thế ContractType enum
  startDate   DateTime
  endDate     DateTime?
  salary      Decimal       @db.Decimal(12, 2)
  position    String?
  department  String?
  fileUrl     String?
  statusId    String?       // Thay thế ContractStatus enum
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  type        Type          @relation("ContractType", fields: [typeId], references: [id])
  status      Type?         @relation("ContractStatus", fields: [statusId], references: [id])
  employee    Employee      @relation(fields: [employeeId], references: [id])
  createdBy   User          @relation("ContractCreator", fields: [createdById], references: [id])
  createdById String

  @@map("contracts")
}

// ============ DECISIONS ============
model Decision {
  id          String        @id @default(cuid())
  typeId      String        // Thay thế DecisionType enum
  employeeId  String
  title       String
  content     String
  effectiveDate DateTime
  fileUrl     String?
  statusId    String?       // Thay thế DecisionStatus enum
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  type        Type          @relation("DecisionType", fields: [typeId], references: [id])
  status      Type?         @relation("DecisionStatus", fields: [statusId], references: [id])
  employee    Employee      @relation(fields: [employeeId], references: [id])
  createdBy   User          @relation("DecisionCreator", fields: [createdById], references: [id])
  createdById String

  @@map("decisions")
}

// ============ RECRUITMENT (Tuyển dụng) ============
model RecruitmentForm {
  id          String   @id @default(cuid())
  title       String
  description String?
  brand       Brand
  source      String
  link        String   @unique
  // Form customization fields
  formTitle   String?  // Custom title for the application form
  formContent String?  // Custom content/description for the form (HTML or markdown)
  bannerUrl   String?  // URL to banner image for the form
  // UI customization
  primaryColor   String?  @default("#F59E0B") // Primary color (hex)
  secondaryColor String?  // Secondary color (hex)
  backgroundColor String? // Background color (hex)
  textColor      String?  // Text color (hex)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
  candidates  Candidate[]
  fields      FormField[] // Dynamic form fields

  @@map("recruitment_forms")
}

enum FormFieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  DATE
  SELECT
  MULTISELECT
  TEXTAREA
  CHECKBOX
  RADIO
  FILE
}

model FormField {
  id          String   @id @default(cuid())
  formId      String
  name        String   // Field name (for form data)
  label       String   // Display label
  type        FormFieldType
  placeholder String?
  required    Boolean  @default(false)
  order       Int      @default(0) // Display order
  // Field options (for select, radio, checkbox)
  options     Json?    // Array of {value: string, label: string}
  // Validation
  minLength   Int?
  maxLength   Int?
  pattern     String?  // Regex pattern
  // Display settings
  width       String?  @default("full") // full, half, third, quarter
  helpText    String?  // Helper text below field
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form        RecruitmentForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_fields")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  formId      String
  link        String   @unique
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form        RecruitmentForm @relation(fields: [formId], references: [id])
  proposal    RecruitmentProposal?
  candidates  Candidate[]

  @@map("campaigns")
}

model Candidate {
  id              String            @id @default(cuid())
  fullName        String
  email           String?
  phone           String
  cvUrl           String?
  formId          String?
  campaignId      String?
  statusId        String            // Thay thế CandidateStatus enum
  brand           Brand?
  position        String?
  storeId         String?
  notes           String?
  
  // Thông tin bổ sung từ form ứng tuyển
  gender          Gender?
  dateOfBirth     DateTime?
  cccd            String?           // 12 số, text type để giữ số 0 đầu
  currentCity     String?
  currentDistrict String?
  currentWard     String?
  currentStreet   String?
  permanentSameAsCurrent Boolean @default(false)
  permanentCity   String?
  permanentDistrict String?
  permanentWard   String?
  permanentStreet String?
  appliedPosition String?
  appliedPositionOther String?
  availableStartDate DateTime?
  preferredWorkShift String?
  canWorkTet      String?           // "Có" hoặc "Không"
  referrer        String?           // "Nhân viên công ty", "Cộng tác viên", "Không có"
  referrerName    String?
  preferredLocations Json?          // Array các quận/huyện
  workExperience  String?           @db.Text
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  status          Type              @relation("CandidateStatus", fields: [statusId], references: [id])
  form            RecruitmentForm?  @relation(fields: [formId], references: [id])
  campaign        Campaign?         @relation(fields: [campaignId], references: [id])
  store           Store?            @relation(fields: [storeId], references: [id])
  interviews     Interview[]
  proposals       RecruitmentProposal[]

  @@map("candidates")
}

model Interview {
  id          String   @id @default(cuid())
  candidateId String
  interviewerId String
  typeId      String   // Thay thế InterviewType enum
  scheduledAt DateTime
  location    String?
  notes       String?
  resultId    String?  // Thay thế InterviewResult enum
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  type        Type     @relation("InterviewType", fields: [typeId], references: [id])
  result      Type?    @relation("InterviewResult", fields: [resultId], references: [id])
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  interviewer User      @relation(fields: [interviewerId], references: [id])

  @@map("interviews")
}

model RecruitmentProposal {
  id          String            @id @default(cuid())
  title       String
  description String?
  storeId     String?
  positionId  String?
  quantity    Int
  reason      String?
  statusId    String?           // Thay thế ProposalStatus enum
  approverId  String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  rejectionReason String?
  campaignId  String?           @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  status      Type?             @relation("ProposalStatus", fields: [statusId], references: [id])
  store       Store?            @relation(fields: [storeId], references: [id])
  position    Position?         @relation(fields: [positionId], references: [id])
  approver    User?             @relation("ProposalApprover", fields: [approverId], references: [id])
  campaign    Campaign?         @relation(fields: [campaignId], references: [id])
  candidates  Candidate[]

  @@map("recruitment_proposals")
}

enum HeadcountPeriod {
  MONTH
  QUARTER
  HALF_YEAR
  YEAR
}

model Headcount {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  period      HeadcountPeriod
  departmentId String?
  storeId     String?
  year        Int
  month       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  department  Department? @relation(fields: [departmentId], references: [id])
  store       Store?      @relation(fields: [storeId], references: [id])
  positions   HeadcountPosition[]

  @@map("headcounts")
}

model HeadcountPosition {
  id          String   @id @default(cuid())
  headcountId String
  positionId  String
  current     Int      @default(0)
  target      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcount   Headcount @relation(fields: [headcountId], references: [id], onDelete: Cascade)
  position    Position  @relation(fields: [positionId], references: [id])

  @@unique([headcountId, positionId])
  @@map("headcount_positions")
}

// ============ TIMEKEEPING (Chấm công) ============
model Timekeeping {
  id            String    @id @default(cuid())
  employeeId    String
  userId        String?
  date          DateTime  @db.Date
  checkInTime   DateTime?
  checkOutTime  DateTime?
  checkInLat    Float?
  checkInLng    Float?
  checkOutLat   Float?
  checkOutLng   Float?
  workHours     Float?
  overtimeHours Float?
  statusId      String?   // Thay thế TimekeepingStatus enum
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  status        Type?     @relation("TimekeepingStatus", fields: [statusId], references: [id])
  employee      Employee  @relation(fields: [employeeId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])

  @@unique([employeeId, date])
  @@map("timekeeping")
}

// ============ PAYROLL (Bảng lương) ============
model Payroll {
  id              String   @id @default(cuid())
  employeeId      String
  userId          String?
  month           Int
  year            Int
  baseSalary      Decimal  @db.Decimal(12, 2)
  workDays        Int
  workHours       Float
  overtimeHours   Float    @default(0)
  overtimePay     Decimal  @db.Decimal(12, 2) @default(0)
  allowances      Decimal  @db.Decimal(12, 2) @default(0)
  deductions      Decimal  @db.Decimal(12, 2) @default(0)
  grossSalary     Decimal  @db.Decimal(12, 2)
  tax             Decimal  @db.Decimal(12, 2) @default(0)
  insurance       Decimal  @db.Decimal(12, 2) @default(0)
  netSalary       Decimal  @db.Decimal(12, 2)
  statusId        String?  // Thay thế PayrollStatus enum
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  status          Type?    @relation("PayrollStatus", fields: [statusId], references: [id])
  employee        Employee @relation(fields: [employeeId], references: [id])
  user            User?    @relation(fields: [userId], references: [id])
  department      Department? @relation(fields: [departmentId], references: [id])
  departmentId    String?

  @@unique([employeeId, month, year])
  @@map("payrolls")
}
