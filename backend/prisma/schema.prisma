generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  fullName   String
  phone      String?
  role       String   @default("USER")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  interviews    Interview[]
  createdProposals RecruitmentProposal[] @relation("ProposalCreator")
  picCandidates Candidate[] @relation("CandidatePIC")
  managedStore  Store?      @relation("StoreSM")

  managedStores Store[]    @relation("StoreAM")

  auditLogs     CandidateAuditLog[]
  communications CandidateCommunicationLog[]
  notifications Notification[] @relation("NotificationRecipient")
  sentNotifications Notification[] @relation("NotificationSender")
  proposalWorkflows ProposalWorkflow[]

  @@map("users")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcounts  Headcount[]
  proposals   RecruitmentProposal[]
  candidates  Candidate[]

  @@map("departments")
}

model Position {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcountPositions HeadcountPosition[]
  proposals   RecruitmentProposal[]
  forms      RecruitmentForm[]
  campaigns   Campaign[]

  @@map("positions")
}

model Store {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String
  city        String?
  zone        String?
  brand       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  smId        String?  @unique
  sm          User?    @relation("StoreSM", fields: [smId], references: [id])

  amId        String?
  am          User?    @relation("StoreAM", fields: [amId], references: [id])

  amName     String?
  omName     String?
  odName     String?
  group      String?

  candidates  Candidate[]
  campaigns   Campaign[]
  headcounts  Headcount[]
  proposals   RecruitmentProposal[]

  @@map("stores")
}

model RecruitmentForm {
  id          String   @id @default(cuid())
  title       String
  description String?
  brand       String
  source      String
  link        String   @unique
  formTitle   String?
  formContent String?
  bannerUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
  candidates  Candidate[]
  fields      FormField[]
  positions   Position[]

  @@map("recruitment_forms")
}

model FormField {
  id          String   @id @default(cuid())
  formId      String
  name        String
  label       String
  type        String
  placeholder String?
  required    Boolean  @default(false)
  order       Int      @default(0)
  options     Json?
  width       String?
  helpText    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form        RecruitmentForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_fields")
}

model Campaign {
  id           String    @id @default(cuid())
  name         String
  description  String?
  formId       String
  positionId   String?
  link         String?   @unique
  startDate    DateTime?
  endDate      DateTime?
  isUntilFilled Boolean  @default(false)
  isActive     Boolean   @default(true)
  storeId      String?
  proposalId   String?   @unique

  // Fulfillment tracking
  targetQty    Int       @default(0)
  fulfilledQty Int       @default(0)
  hiredQty     Int       @default(0)
  offerAcceptedQty Int   @default(0)
  status       String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, CANCELLED

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Soft delete & version control
  deletedAt    DateTime?
  version      Int       @default(1)

  form         RecruitmentForm  @relation(fields: [formId], references: [id])
  position     Position?        @relation(fields: [positionId], references: [id])
  store        Store?          @relation(fields: [storeId], references: [id])
  candidates   Candidate[]
  auditLogs    CandidateAuditLog[]
  offers       Offer[]
  proposal     RecruitmentProposal? @relation("ProposalCampaign", fields: [proposalId], references: [id])

  // Database constraints
  @@index([storeId, status])
  @@index([positionId, isActive])
  @@map("campaigns")
}

model Candidate {
  id              String   @id @default(cuid())
  fullName        String
  email           String?
  phone           String   @db.VarChar(20)
  cvUrl           String?
  formId          String?
  campaignId      String?
  proposalId      String?
  sourceId        String?
  source          Source?        @relation(fields: [sourceId], references: [id])
  brand           String?
  position        String?
  storeId         String?
  departmentId    String?
  statusId        String?
  status          CandidateStatus?  @relation(fields: [statusId], references: [id])
  notes           String?
  gender          String?
  dateOfBirth     DateTime?
  cccd            String?  @db.VarChar(12)
  currentCity     String?
  currentWard     String?
  currentStreet   String?
  permanentSameAsCurrent Boolean? @default(false)
  permanentCity   String?
  permanentWard   String?
  permanentStreet String?
  appliedPosition String?
  appliedPositionOther String?
  availableStartDate DateTime?
  canWorkTet      String?
  referrer        String?
  referrerName    String?
  preferredLocations String[] @default([])
  workExperience  String?

  // SLA & Priority
  priority        String    @default("NORMAL") // URGENT, HIGH, NORMAL, LOW
  slaDueDate      DateTime?
  slaBreachFlag   Boolean   @default(false)

  // Blacklist tracking
  isBlacklisted   Boolean   @default(false)
  blacklistedAt   DateTime?
  blacklistReason String?
  blacklistId     String?
  blacklist       Blacklist? @relation(fields: [blacklistId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Soft delete & version control
  deletedAt       DateTime?
  version         Int      @default(1)  // For optimistic locking

  form            RecruitmentForm?  @relation(fields: [formId], references: [id])
  campaign        Campaign?         @relation(fields: [campaignId], references: [id])
  proposal        RecruitmentProposal? @relation("CandidateDirectProposal", fields: [proposalId], references: [id])
  store           Store?           @relation(fields: [storeId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])

  picId           String?
  pic             User?            @relation("CandidatePIC", fields: [picId], references: [id])

  interviews      Interview[]
  auditLogs       CandidateAuditLog[]
  slaLogs         CandidateSLALog[]
  communications  CandidateCommunicationLog[]
  offers          Offer[]

  // Database constraints
  @@index([storeId, statusId])
  @@index([campaignId, statusId])
  @@index([phone, storeId])
  @@map("candidates")
}

model CandidateStatus {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  color       String?
  group       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  slaHours    Int?     // SLA duration in hours for this stage
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidates  Candidate[]

  @@map("candidate_statuses")
}

model Interview {
  id           String   @id @default(cuid())
  candidateId  String
  interviewerId String
  type         String?  // e.g., PHONE, VIDEO, ONSITE
  result       String?  // e.g., PASS, FAIL, PENDING
  position     String?  // Position name at time of interview
  scheduledAt  DateTime
  completedAt  DateTime?
  location    String?
  notes       String?
  rating      Int?     // 1-5 scale
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate    Candidate  @relation(fields: [candidateId], references: [id])
  interviewer  User       @relation(fields: [interviewerId], references: [id])

  // Database constraints
  @@index([candidateId, scheduledAt])
  @@index([interviewerId, scheduledAt])
  @@index([scheduledAt])
  @@map("interviews")
}

model RecruitmentProposal {
  id           String   @id @default(cuid())
  title        String
  description  String?
  storeId      String?
  positionId   String?
  quantity     Int      @default(1) // Must be at least 1
  reason       String?
  businessReason String? // e.g., EXPANSION, REPLACEMENT, SEASONAL, NEW_OPENING
  replacementFor String? // Employee ID or name being replaced

  // Enhanced request fields
  urgency      String   @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  budget       Float?   // Monthly budget per head
  targetJoinDate DateTime?
  isUnplanned  Boolean  @default(false)

  // Workflow tracking
  status       String   @default("DRAFT") // DRAFT, SUBMITTED, AM_REVIEWED, HR_ACCEPTED, APPROVED, REJECTED, CANCELLED
  requestedById String?
  amReviewedAt DateTime?
  hrAssignedAt DateTime?
  approverId   String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  rejectionReason String?
  cancelledAt DateTime?
  cancelledById String?

  campaignId  String?
  departmentId String?
  startDate    DateTime?
  endDate      DateTime?
  isUntilFilled Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft delete & version control
  deletedAt   DateTime?
  version     Int       @default(1)

  store        Store?          @relation(fields: [storeId], references: [id])
  position     Position?       @relation(fields: [positionId], references: [id])
  approver     User?           @relation("ProposalCreator", fields: [approverId], references: [id])
  department  Department?    @relation(fields: [departmentId], references: [id])
  candidates  Candidate[]     @relation("CandidateDirectProposal")
  campaign    Campaign?       @relation("ProposalCampaign")
  workflowHistory ProposalWorkflow[]
  fulfillment ProposalFulfillment?

  // Database constraints
  @@index([storeId, status])
  @@index([positionId, status])
  @@index([requestedById, status])
  @@map("recruitment_proposals")
}

model ProposalWorkflow {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    RecruitmentProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  fromStatus  String
  toStatus    String
  action      String   // SUBMIT, REVIEW, APPROVE, REJECT, CANCEL, ASSIGN
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  actorRole   String   // SM, AM, HR, ADMIN
  notes       String?
  createdAt   DateTime @default(now())

  @@map("proposal_workflows")
}

model ProposalFulfillment {
  id           String   @id @default(cuid())
  proposalId   String   @unique
  proposal     RecruitmentProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  requestedQty Int
  hiredQty     Int      @default(0)
  onboardedQty Int      @default(0)
  
  completionRate Float  @default(0)
  lastUpdatedAt  DateTime @updatedAt

  @@map("proposal_fulfillments")
}

model Headcount {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  period       String
  departmentId String?
  storeId      String?
  year         Int
  month        Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id])
  store        Store?      @relation(fields: [storeId], references: [id])
  positions    HeadcountPosition[]

  @@map("headcounts")
}

model HeadcountPosition {
  id          String   @id @default(cuid())
  headcountId String
  positionId  String
  current     Int      @default(0)
  target      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcount   Headcount @relation(fields: [headcountId], references: [id], onDelete: Cascade)
  position    Position  @relation(fields: [positionId], references: [id])

  @@unique([headcountId, positionId])
  @@map("headcount_position")
}

model CandidateToRecruit {
  id           String   @id @default(cuid())
  candidateId  String
  proposalId   String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  @@map("_candidate_to_recruit")
}

model Source {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  link        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidates  Candidate[]

  @@map("sources")
}

// Audit trail for all candidate changes
model CandidateAuditLog {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  actorId     String?
  actor       User?     @relation(fields: [actorId], references: [id])
  
  action      String    // STATUS_CHANGE, PIC_ASSIGN, CAMPAIGN_TRANSFER, INTERVIEW_SCHEDULED, OFFER_SENT, etc.
  fromValue   String?
  toValue     String?
  metadata    Json?     // Additional context
  notes       String?
  
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  
  createdAt   DateTime @default(now())

  @@index([candidateId, createdAt])
  @@map("candidate_audit_logs")
}

// SLA tracking per candidate status transition
model CandidateSLALog {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  statusCode  String
  enteredAt   DateTime
  exitedAt    DateTime?
  slaHours    Int      // Expected SLA for this stage
  breached    Boolean  @default(false)
  breachHours Int?     // How many hours over SLA
  
  createdAt   DateTime @default(now())

  @@index([candidateId, statusCode])
  @@map("candidate_sla_logs")
}

// Blacklist management
model Blacklist {
  id          String   @id @default(cuid())
  phoneHash   String?  @unique  // Hashed phone for lookup
  emailHash   String?  @unique  // Hashed email for lookup
  phone       String?           // Original (encrypted or raw based on policy)
  email       String?
  fullName    String?
  reason      String            // NO_SHOW, FAKE_INFO, VIOLATION, OTHER
  reasonDetail String?
  recruiterNote String?
  expiryDate  DateTime?         // Auto-expire blacklist entry
  isPermanent Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidates  Candidate[]

  @@map("blacklists")
}

// Offer management
model Offer {
  id              String   @id @default(cuid())
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id])
  
  status          String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, WITHDRAWN
  sentAt          DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  expiredAt       DateTime?
  
  // Offer details
  position        String?
  department      String?
  storeId         String?
  salary          Float?
  probationLength Int?     // Months
  probationSalary Float?
  startDate       DateTime?
  benefits        String?
  notes           String?
  rejectionReason String?
  
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documents       OfferDocument[]

  @@map("offers")
}

model OfferDocument {
  id          String   @id @default(cuid())
  offerId     String
  offer       Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  
  name        String
  type        String   // OFFER_LETTER, CONTRACT, ID_COPY, CERTIFICATE, OTHER
  url         String
  uploadedById String?
  createdAt   DateTime @default(now())

  @@map("offer_documents")
}

// Communication log
model CandidateCommunicationLog {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  type        String   // EMAIL, PHONE, SMS, ZALO, MEETING, NOTE
  direction   String   // INBOUND, OUTBOUND
  content     String
  subject     String?
  senderId    String?
  sender      User?     @relation(fields: [senderId], references: [id])
  
  createdAt   DateTime @default(now())

  @@index([candidateId, createdAt])
  @@map("candidate_communication_logs")
}

// Notification system
model Notification {
  id          String   @id @default(cuid())
  recipientId String
  recipient   User     @relation("NotificationRecipient", fields: [recipientId], references: [id])
  
  senderId    String?
  sender      User?    @relation("NotificationSender", fields: [senderId], references: [id])
  
  type        String   // SLA_BREACH, STATUS_CHANGE, PROPOSAL_APPROVAL, INTERVIEW_REMINDER, etc.
  title       String
  message     String
  entityType  String?  // CANDIDATE, PROPOSAL, CAMPAIGN, INTERVIEW
  entityId    String?
  
  isRead      Boolean  @default(false)
  readAt      DateTime?
  actionUrl   String?
  
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead, createdAt])
  @@map("notifications")
}

model AdministrativeRegion {
  id           Int      @id
  name         String
  nameEn       String   @map("name_en")
  codeName     String?  @map("code_name")
  codeNameEn   String?  @map("code_name_en")

  @@map("administrative_regions")
}

model AdministrativeUnit {
  id           Int      @id
  fullName     String?  @map("full_name")
  fullNameEn   String?  @map("full_name_en")
  shortName    String?  @map("short_name")
  shortNameEn  String?  @map("short_name_en")
  codeName     String?  @map("code_name")
  codeNameEn   String?  @map("code_name_en")
  provinces    Province[]
  wards        Ward[]

  @@map("administrative_units")
}

model Province {
  code                  String              @id @db.VarChar(20)
  name                  String
  nameEn                String?             @map("name_en")
  fullName              String              @map("full_name")
  fullNameEn            String?             @map("full_name_en")
  codeName              String?             @map("code_name")
  administrativeUnitId  Int?                @map("administrative_unit_id")
  
  administrativeUnit    AdministrativeUnit? @relation(fields: [administrativeUnitId], references: [id])
  wards                 Ward[]

  @@map("provinces")
}

model Ward {
  code                  String              @id @db.VarChar(20)
  name                  String
  nameEn                String?             @map("name_en")
  fullName              String?             @map("full_name")
  fullNameEn            String?             @map("full_name_en")
  codeName              String?             @map("code_name")
  provinceCode          String?             @map("province_code") @db.VarChar(20)
  administrativeUnitId  Int?                @map("administrative_unit_id")
  
  province              Province?           @relation(fields: [provinceCode], references: [code])
  administrativeUnit    AdministrativeUnit? @relation(fields: [administrativeUnitId], references: [id])

  @@map("wards")
}

