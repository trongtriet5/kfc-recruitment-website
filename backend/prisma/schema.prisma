generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  fullName   String
  phone      String?
  role       String   @default("USER")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  interviews    Interview[]
  campaigns     Campaign[]
  createdProposals RecruitmentProposal[] @relation("ProposalCreator")
  picCandidates Candidate[] @relation("CandidatePIC")
  managedStore  Store?      @relation("StoreSM")

  managedStores Store[]    @relation("StoreAM")

  @@map("users")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
  headcounts  Headcount[]
  proposals   RecruitmentProposal[]
  candidates  Candidate[]

  @@map("departments")
}

model Position {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcountPositions HeadcountPosition[]
  proposals   RecruitmentProposal[]
  interviews  Interview[]
  forms      RecruitmentForm[]

  @@map("positions")
}

model Store {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String
  city        String?
  zone        String?
  brand       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  smId        String?  @unique
  sm          User?    @relation("StoreSM", fields: [smId], references: [id])

  amId        String?
  am          User?    @relation("StoreAM", fields: [amId], references: [id])

  amName     String?
  omName     String?
  odName     String?
  group      String?

  candidates  Candidate[]
  campaigns   Campaign[]
  headcounts  Headcount[]
  proposals   RecruitmentProposal[]

  @@map("stores")
}

model RecruitmentForm {
  id          String   @id @default(cuid())
  title       String
  description String?
  brand       String
  source      String
  link        String   @unique
  formTitle   String?
  formContent String?
  bannerUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
  candidates  Candidate[]
  fields      FormField[]
  positions   Position[]

  @@map("recruitment_forms")
}

model FormField {
  id          String   @id @default(cuid())
  formId      String
  name        String
  label       String
  type        String
  placeholder String?
  required    Boolean  @default(false)
  order       Int      @default(0)
  options     Json?
  width       String?
  helpText    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form        RecruitmentForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_fields")
}

model Campaign {
  id           String    @id @default(cuid())
  name         String
  description  String?
  formId       String
  link         String?   @unique
  startDate    DateTime?
  endDate      DateTime?
  isUntilFilled Boolean  @default(false)
  isActive     Boolean   @default(true)
  picId        String?
  departmentId String?
  storeId      String?
  proposalId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  form         RecruitmentForm  @relation(fields: [formId], references: [id])
  pic          User?           @relation(fields: [picId], references: [id])
  department   Department?     @relation(fields: [departmentId], references: [id])
  store        Store?          @relation(fields: [storeId], references: [id])
  candidates   Candidate[]

  @@map("campaigns")
}

model Candidate {
  id              String   @id @default(cuid())
  fullName        String
  email           String?
  phone           String
  cvUrl           String?
  formId          String?
  campaignId      String?
  sourceId        String?
  source          Source?        @relation(fields: [sourceId], references: [id])
  brand           String?
  position        String?
  storeId         String?
  departmentId    String?
  statusId        String?
  status          CandidateStatus?  @relation(fields: [statusId], references: [id])
  notes           String?
  gender          String?
  dateOfBirth     DateTime?
  cccd           String?
  currentCity    String?
  currentWard    String?
  currentStreet  String?
  permanentSameAsCurrent Boolean? @default(false)
  permanentCity  String?
  permanentWard  String?
  permanentStreet String?
  appliedPosition String?
  appliedPositionOther String?
  availableStartDate DateTime?
  canWorkTet     String?
  referrer       String?
  referrerName   String?
  preferredLocations String[] @default([])
  workExperience  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  form            RecruitmentForm?  @relation(fields: [formId], references: [id])
  campaign        Campaign?         @relation(fields: [campaignId], references: [id])
  store           Store?           @relation(fields: [storeId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  
  picId           String?
  pic             User?            @relation("CandidatePIC", fields: [picId], references: [id])
  
  interviews      Interview[]
  proposals       RecruitmentProposal[]

  @@map("candidates")
}

model CandidateStatus {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  color       String?
  group       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidates  Candidate[]

  @@map("candidate_statuses")
}

model Interview {
  id           String   @id @default(cuid())
  candidateId  String
  interviewerId String
  typeId       String?
  resultId     String?
  positionId   String?
  scheduledAt  DateTime
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate    Candidate  @relation(fields: [candidateId], references: [id])
  interviewer  User       @relation(fields: [interviewerId], references: [id])
  position     Position?  @relation(fields: [positionId], references: [id])

  @@map("interviews")
}

model RecruitmentProposal {
  id           String   @id @default(cuid())
  title        String
  description  String?
  storeId      String?
  positionId   String?
  quantity     Int
  reason       String?
  status       String   @default("PENDING")
  approverId   String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  campaignId  String?
  departmentId String?
  startDate    DateTime?
  endDate      DateTime?
  isUntilFilled Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store        Store?          @relation(fields: [storeId], references: [id])
  position     Position?       @relation(fields: [positionId], references: [id])
  approver     User?           @relation("ProposalCreator", fields: [approverId], references: [id])
  department  Department?    @relation(fields: [departmentId], references: [id])
  candidates  Candidate[]

  @@map("recruitment_proposals")
}

model Headcount {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  period       String
  departmentId String?
  storeId      String?
  year         Int
  month        Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id])
  store        Store?      @relation(fields: [storeId], references: [id])
  positions    HeadcountPosition[]

  @@map("headcounts")
}

model HeadcountPosition {
  id          String   @id @default(cuid())
  headcountId String
  positionId  String
  current     Int      @default(0)
  target      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcount   Headcount @relation(fields: [headcountId], references: [id], onDelete: Cascade)
  position    Position  @relation(fields: [positionId], references: [id])

  @@unique([headcountId, positionId])
  @@map("headcount_position")
}

model CandidateToRecruit {
  id           String   @id @default(cuid())
  candidateId  String
  proposalId   String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  @@map("_candidate_to_recruit")
}

model Source {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  link        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidates  Candidate[]

  @@map("sources")
}

model AdministrativeRegion {
  id           Int      @id
  name         String
  nameEn       String   @map("name_en")
  codeName     String?  @map("code_name")
  codeNameEn   String?  @map("code_name_en")

  @@map("administrative_regions")
}

model AdministrativeUnit {
  id           Int      @id
  fullName     String?  @map("full_name")
  fullNameEn   String?  @map("full_name_en")
  shortName    String?  @map("short_name")
  shortNameEn  String?  @map("short_name_en")
  codeName     String?  @map("code_name")
  codeNameEn   String?  @map("code_name_en")
  provinces    Province[]
  wards        Ward[]

  @@map("administrative_units")
}

model Province {
  code                  String              @id @db.VarChar(20)
  name                  String
  nameEn                String?             @map("name_en")
  fullName              String              @map("full_name")
  fullNameEn            String?             @map("full_name_en")
  codeName              String?             @map("code_name")
  administrativeUnitId  Int?                @map("administrative_unit_id")
  
  administrativeUnit    AdministrativeUnit? @relation(fields: [administrativeUnitId], references: [id])
  wards                 Ward[]

  @@map("provinces")
}

model Ward {
  code                  String              @id @db.VarChar(20)
  name                  String
  nameEn                String?             @map("name_en")
  fullName              String?             @map("full_name")
  fullNameEn            String?             @map("full_name_en")
  codeName              String?             @map("code_name")
  provinceCode          String?             @map("province_code") @db.VarChar(20)
  administrativeUnitId  Int?                @map("administrative_unit_id")
  
  province              Province?           @relation(fields: [provinceCode], references: [code])
  administrativeUnit    AdministrativeUnit? @relation(fields: [administrativeUnitId], references: [id])

  @@map("wards")
}
