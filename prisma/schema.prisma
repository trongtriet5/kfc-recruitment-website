// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH & USER ============
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password     String
  fullName     String
  phone        String?
  role         UserRole @default(USER)
  departmentId String?
  positionId   String?
  employeeId   String?  @unique
  isActive     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  department    Department? @relation(fields: [departmentId], references: [id])
  position      Position?   @relation(fields: [positionId], references: [id])
  employee     Employee?   @relation("EmployeeUser", fields: [employeeId], references: [id])

  interviews   Interview[]
  proposalCreator RecruitmentProposal[] @relation("ProposalCreator")
  approver    RecruitmentProposal[] @relation("ProposalApprover")
  payrolls    Payroll[]
  timekeeping Timekeeping[]

  @@map("users")
}

enum UserRole {
  ADMIN
  TA
  AM
  SM
  USER
}

// ============ ORGANIZATION ============
model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  employees   Employee[]
  payrolls    Payroll[]

  @@map("departments")
}

model Position {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  employees   Employee[]
  headcountPositions HeadcountPosition[]
  proposals   RecruitmentProposal[]

  @@map("positions")
}

model Store {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  district   String?
  city       String?
  am          String?
  om          String?
  od          String?
  zone       String?
  area       String?
  taIncharge  String?
  group      StoreGroup?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees   Employee[]
  proposals   RecruitmentProposal[]
  headcounts  Headcount[]
  candidates Candidate[]

  @@map("stores")
}

enum StoreGroup {
  OPS_SOUTH
  OPS_NORTH
}



// ============ EMPLOYEE ============
model Employee {
  id              String          @id @default(cuid())
  employeeCode    String          @unique
  fullName        String
  email           String?         @unique
  phone           String
  gender          Gender
  dateOfBirth     DateTime?
  address         String?
  idCard          String?
  education       Education
  status          EmployeeStatus  @default(PENDING)
  departmentId    String?
  positionId      String?
  storeId         String?
  
  contractType    ContractType?
  startDate       DateTime?
  endDate         DateTime?
  salary          Decimal?        @db.Decimal(12, 2)
  insuranceNumber String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  department      Department?     @relation(fields: [departmentId], references: [id])
  position        Position?       @relation(fields: [positionId], references: [id])
  store           Store?          @relation(fields: [storeId], references: [id])
  user            User?            @relation("EmployeeUser")
  payrolls       Payroll[]
  timekeeping    Timekeeping[]

  @@map("employees")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Education {
  HIGH_SCHOOL
  VOCATIONAL
  COLLEGE
  UNIVERSITY
  POSTGRADUATE
}

enum EmployeeStatus {
  PENDING
  WORKING
  PROBATION
  TEMPORARY_LEAVE
  RESIGNED
}

enum ContractType {
  APPRENTICESHIP
  VOCATIONAL_TRAINING
  FIXED_12_MONTHS_1
  FIXED_14_MONTHS_1
  FIXED_24_MONTHS_1
  FIXED_36_MONTHS_1
  PROBATION
  SERVICE
  INDEFINITE
  FIXED_12_MONTHS_2
  FIXED_14_MONTHS_2
  FIXED_24_MONTHS_2
  FIXED_36_MONTHS_2
}

// ============ RECRUITMENT ============
model RecruitmentForm {
  id          String   @id @default(cuid())
  title       String
  description String?
  source      String
  link        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   Campaign[]
  candidates  Candidate[]

  @@map("recruitment_forms")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  formId      String
  link        String   @unique
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form        RecruitmentForm @relation(fields: [formId], references: [id])
  candidates  Candidate[]

  @@map("campaigns")
}

model Candidate {
  id              String            @id @default(cuid())
  fullName        String
  email           String?
  phone           String
  cvUrl           String?
  formId          String?
  campaignId     String?
  status         CandidateStatus
  position       String?
  storeId        String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  form            RecruitmentForm?  @relation(fields: [formId], references: [id])
  campaign        Campaign?         @relation(fields: [campaignId], references: [id])
  store           Store?            @relation(fields: [storeId], references: [id])
  interviews     Interview[]
  proposals      RecruitmentProposal[]

  @@map("candidates")
}

enum CandidateStatus {
  CV_FILTERING
  CV_PASSED
  CV_FAILED
  BLACKLIST
  CANNOT_CONTACT
  AREA_NOT_RECRUITING
  WAITING_INTERVIEW
  HR_INTERVIEW_PASSED
  HR_INTERVIEW_FAILED
  SM_AM_INTERVIEW_PASSED
  SM_AM_INTERVIEW_FAILED
  SM_AM_INTERVIEW_NO_SHOW
  OM_PV_INTERVIEW_PASSED
  OM_PV_INTERVIEW_FAILED
  OM_PV_INTERVIEW_NO_SHOW
  OFFER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  WAITING_ONBOARDING
  ONBOARDING_ACCEPTED
  ONBOARDING_REJECTED
}

model Interview {
  id           String   @id @default(cuid())
  candidateId  String
  interviewerId String
  type         InterviewType
  scheduledAt DateTime
  location    String?
  notes       String?
  result      InterviewResult?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate   Candidate @relation(fields: [candidateId], references: [id])
  interviewer User      @relation(fields: [interviewerId], references: [id])

  @@map("interviews")
}

enum InterviewType {
  HR_SCREENING
  SM_AM_INTERVIEW
  OM_PV_INTERVIEW
}

enum InterviewResult {
  PASSED
  FAILED
  NO_SHOW
}

model RecruitmentProposal {
  id          String            @id @default(cuid())
  title       String
  description String?
  storeId     String?
  positionId  String?
  quantity   Int
  reason     String?
  status     ProposalStatus    @default(PENDING)
  approverId  String?
  approvedAt DateTime?
  rejectedAt DateTime?
  creatorId  String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  store      Store?            @relation(fields: [storeId], references: [id])
  position   Position?         @relation(fields: [positionId], references: [id])
  approver   User?             @relation("ProposalApprover", fields: [approverId], references: [id])
  creator   User?             @relation("ProposalCreator", fields: [creatorId], references: [id])
  candidates Candidate[]

  @@map("recruitment_proposals")
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============ HEADCOUNT ============
enum HeadcountPeriod {
  MONTH
  QUARTER
  HALF_YEAR
  YEAR
}

model Headcount {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  period       HeadcountPeriod
  storeId      String?
  current      Int      @default(0)
  target       Int
  year         Int
  month        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store?            @relation(fields: [storeId], references: [id])
  positions   HeadcountPosition[]

  @@map("headcounts")
}

model HeadcountPosition {
  id          String   @id @default(cuid())
  headcountId String
  positionId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  headcount   Headcount @relation(fields: [headcountId], references: [id], onDelete: Cascade)
  position   Position @relation(fields: [positionId], references: [id])

  @@unique([headcountId, positionId])
  @@map("headcount_positions")
}

// ============ TIMEKEEPING & PAYROLL ============
model Payroll {
  id              String   @id @default(cuid())
  employeeId       String
  userId          String?
  month           Int
  year            Int
  baseSalary      Decimal  @db.Decimal(12, 2)
  workDays        Int
  workHours       Float
  overtimeHours   Float    @default(0)
  overtimePay    Decimal  @db.Decimal(12, 2) @default(0)
  allowances    Decimal  @db.Decimal(12, 2) @default(0)
  deductions    Decimal  @db.Decimal(12, 2) @default(0)
  grossSalary   Decimal  @db.Decimal(12, 2)
  tax           Decimal  @db.Decimal(12, 2) @default(0)
  insurance     Decimal  @db.Decimal(12, 2) @default(0)
  netSalary    Decimal  @db.Decimal(12, 2)
  status        PayrollStatus @default(PENDING)
  paidAt       DateTime?
  notes         String?
  createdAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  @@unique([employeeId, month, year])
  @@map("payrolls")
}

enum PayrollStatus {
  PENDING
  CALCULATED
  APPROVED
  PAID
  CANCELLED
}

model Timekeeping {
  id             String    @id @default(cuid())
  employeeId     String
  userId         String?
  date          DateTime  @db.Date
  checkInTime   DateTime?
  checkOutTime  DateTime?
  checkInLat    Float?
  checkInLng    Float?
  checkOutLat   Float?
  checkOutLng   Float?
  workHours    Float?
  overtimeHours Float?
  status       TimekeepingStatus @default(NORMAL)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([employeeId, date])
  @@map("timekeeping")
}

enum TimekeepingStatus {
  NORMAL
  LATE
  EARLY_LEAVE
  ABSENT
  OVERTIME
}